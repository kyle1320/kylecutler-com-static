{
  "name": "kylecutler-com-static",
  "version": "0.0.1",
  "dependencies": {
    "@babel/core": "^7.4.5",
    "@babel/plugin-transform-runtime": "^7.4.4",
    "@babel/runtime": "^7.4.5",
    "@types/node": "^12.0.8",
    "@typescript-eslint/eslint-plugin": "^1.10.2",
    "@typescript-eslint/parser": "^1.10.2",
    "eslint": "^5.16.0",
    "jscolor-picker": "^2.0.4",
    "parcel": "^1.12.3",
    "path2d-polyfill": "^0.4.1",
    "pug": "^2.0.3",
    "sass": "^1.21.0",
    "three": "^0.105.2",
    "typescript": "^3.5.2"
  },
  "browserslist": "> 0.25%, not dead",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .js,.ts,.jsx,.tsx",
    "verify": "npm run typecheck && npm run lint",
    "build": "parcel build src/**/*.pug --experimental-scope-hoisting",
    "deploy": "npm run verify && npm run build",
    "watch": "parcel src/**/*.pug"
  },
  "engines": {}
}
